# === Segfy API integration ===
#
# SEGFY_API_URL: server-only (não é exposta ao browser). Usada pelos rewrites em
# next.config.mjs.
#   - Local:  http://localhost:5000
#   - Docker: http://localhost:8080
#   - Render: https://<seu-app>.onrender.com
SEGFY_API_URL=http://localhost:5000

# NEXT_PUBLIC_API_BASE_URL: exposta ao browser. Path relativo — o Next reescreve
# /api/segfy/* para ${SEGFY_API_URL}/api/v1/*. Sem CORS, sem exposição da URL real.
NEXT_PUBLIC_API_BASE_URL=/api/segfy
